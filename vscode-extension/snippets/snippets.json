{
  "Simple Moving Average": {
    "prefix": "ma",
    "body": "MA(${1:data}, ${2:period})",
    "description": "Simple Moving Average"
  },
  "Exponential Moving Average": {
    "prefix": "ema",
    "body": "EMA(${1:data}, ${2:period})",
    "description": "Exponential Moving Average"
  },
  "Sum": {
    "prefix": "sum",
    "body": "SUM(${1:data}, ${2:period})",
    "description": "Sum of values over period"
  },
  "Maximum": {
    "prefix": "max",
    "body": "MAX(${1:a}, ${2:b})",
    "description": "Maximum of two values"
  },
  "Minimum": {
    "prefix": "min",
    "body": "MIN(${1:a}, ${2:b})",
    "description": "Minimum of two values"
  },
  "Highest High Value": {
    "prefix": "hhv",
    "body": "HHV(${1:data}, ${2:period})",
    "description": "Highest value over period"
  },
  "Lowest Low Value": {
    "prefix": "llv",
    "body": "LLV(${1:data}, ${2:period})",
    "description": "Lowest value over period"
  },
  "Reference": {
    "prefix": "ref",
    "body": "REF(${1:data}, ${2:period})",
    "description": "Reference value from N bars ago"
  },
  "If Condition": {
    "prefix": "if",
    "body": "IF(${1:condition}, ${2:true_value}, ${3:false_value})",
    "description": "If condition then else"
  },
  "Cross": {
    "prefix": "cross",
    "body": "CROSS(${1:a}, ${2:b})",
    "description": "Check if a crosses above b"
  },
  "Every": {
    "prefix": "every",
    "body": "EVERY(${1:condition}, ${2:period})",
    "description": "Check if condition is true for all bars in period"
  },
  "Exist": {
    "prefix": "exist",
    "body": "EXIST(${1:condition}, ${2:period})",
    "description": "Check if condition exists in period"
  },
  "Bars Last": {
    "prefix": "barslast",
    "body": "BARSLAST(${1:condition})",
    "description": "Bars since condition was true"
  },
  "Count": {
    "prefix": "count",
    "body": "COUNT(${1:condition}, ${2:period})",
    "description": "Count occurrences of condition in period"
  },
  "Variable Assignment": {
    "prefix": "var",
    "body": "${1:name} := ${2:value};",
    "description": "Assign value to variable"
  },
  "Draw Line Red": {
    "prefix": "drawred",
    "body": "${1:expression}, COLORRED, LINETHICK${2:1};",
    "description": "Draw expression as red line"
  },
  "Draw Line Green": {
    "prefix": "drawgreen",
    "body": "${1:expression}, COLORGREEN, LINETHICK${2:1};",
    "description": "Draw expression as green line"
  },
  "Draw Line Blue": {
    "prefix": "drawblue",
    "body": "${1:expression}, COLORBLUE, LINETHICK${2:1};",
    "description": "Draw expression as blue line"
  },
  "Comment Line": {
    "prefix": "comment",
    "body": "// ${1:comment}",
    "description": "Single-line comment"
  },
  "Block Comment": {
    "prefix": "bcomment",
    "body": "{\n  ${1:comment}\n}",
    "description": "Block comment"
  },
  "Consecutive N Day Rise": {
    "prefix": "upnday",
    "body": "UPNDAY(${1:CLOSE}, ${2:3})",
    "description": "Check for N consecutive rising days"
  },
  "Consecutive N Day Fall": {
    "prefix": "downnday",
    "body": "DOWNNDAY(${1:CLOSE}, ${2:3})",
    "description": "Check for N consecutive falling days"
  },
  "N Day Condition": {
    "prefix": "nday",
    "body": "NDAY(${1:condition}, ${2:3})",
    "description": "Check if condition holds for N days"
  },
  "Range Check": {
    "prefix": "range",
    "body": "RANGE(${1:value}, ${2:min}, ${3:max})",
    "description": "Check if value is in range"
  },
  "Winner Ratio": {
    "prefix": "winner",
    "body": "WINNER(CLOSE, VOLUME, ${1:CLOSE}, ${2:100})",
    "description": "Calculate profit ratio at price level"
  },
  "Value When": {
    "prefix": "valuewhen",
    "body": "VALUEWHEN(${1:condition}, ${2:value})",
    "description": "Get value when condition first true"
  },
  "Top Range": {
    "prefix": "toprange",
    "body": "TOPRANGE(${1:HIGH}, ${2:20})",
    "description": "Check if value is new high"
  },
  "Low Range": {
    "prefix": "lowrange",
    "body": "LOWRANGE(${1:LOW}, ${2:20})",
    "description": "Check if value is new low"
  },
  "Year Filter": {
    "prefix": "year",
    "body": "YEAR = ${1:2024}",
    "description": "Filter by year"
  },
  "Month Filter": {
    "prefix": "month",
    "body": "MONTH = ${1:1}",
    "description": "Filter by month"
  },
  "Time Filter": {
    "prefix": "timefilter",
    "body": "YEAR = ${1:2024} AND MONTH >= ${2:1}",
    "description": "Filter by time period"
  },
  "Weekday Filter": {
    "prefix": "weekday",
    "body": "WEEKDAY = ${1:1}",
    "description": "Filter by weekday (1=Mon, 7=Sun)"
  },
  "Bars Since": {
    "prefix": "barssince",
    "body": "BARSSINCE(${1:condition})",
    "description": "Count bars since condition first true"
  },
  "Is Last Bar": {
    "prefix": "islastbar",
    "body": "ISLASTBAR",
    "description": "Check if current bar is last"
  },
  "Consecutive Rise Strategy": {
    "prefix": "strat-uptrend",
    "body": [
      "UP3 := UPNDAY(CLOSE, 3);",
      "VOL_UP := VOLUME > MA(VOLUME, 5) * 1.2;",
      "SIGNAL: UP3 AND VOL_UP;"
    ],
    "description": "Strategy: consecutive rise with volume confirmation"
  },
  "Time Filtered MA Cross": {
    "prefix": "strat-timefilter",
    "body": [
      "TIME_OK := YEAR = ${1:2024} AND MONTH >= ${2:1};",
      "MA5 := MA(CLOSE, 5);",
      "MA10 := MA(CLOSE, 10);",
      "GOLDEN := CROSS(MA5, MA10);",
      "SIGNAL: TIME_OK AND GOLDEN;"
    ],
    "description": "Strategy: time-filtered MA crossover"
  },
  "Profit Analysis Strategy": {
    "prefix": "strat-winner",
    "body": [
      "WIN_RATIO := WINNER(CLOSE, VOLUME, CLOSE);",
      "LOW_WIN := WIN_RATIO < 0.3;",
      "NEW_HIGH := TOPRANGE(HIGH, 20);",
      "BUY: LOW_WIN AND NEW_HIGH;"
    ],
    "description": "Strategy: profit analysis with breakout"
  }
}
