{
  "comments": {
    "lineComment": "//",
    "blockComment": ["{", "}"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*(\\{|\\().*$",
    "decreaseIndentPattern": "^\\s*[\\}\\)]*$"
  },
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*(?:TODO|FIXME|NOTE|HACK|BUG|OPTIMIZE)",
      "end": "^\\s*//\\s*END"
    }
  },
  "wordPattern": "([a-zA-Z_][a-zA-Z0-9_]*|[0-9]+\\.?[0-9]*)"
}
